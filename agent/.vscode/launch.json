{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Current TS File",
      "runtimeArgs": ["-r", "ts-node/register"],
      "args": ["${file}"],
      "sourceMaps": true,
      "skipFiles": ["<node_internals>/**"],
      "program": "${workspaceFolder}\\src\\index.ts"
    }
  ]
}
